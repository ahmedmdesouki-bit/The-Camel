# ---- Supabase (the data bridge between the Python brain and this web window) ----
# Create a project at https://supabase.com, then Project Settings -> API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# ---- Friends allowlist (app-layer, comma-separated). SECONDARY to the DB allowlist. ----
# The REAL gate is the `allowed_emails` table in Supabase (enforced by RLS — see web/supabase/schema.sql):
# add your + friends' emails there, and DISABLE email self-signup in Supabase. This env var is a
# belt-and-suspenders check in the app; blank here means the app layer allows any signed-in user, but the
# DB still blocks anyone not in `allowed_emails`.
NEXT_PUBLIC_ALLOWED_EMAILS=you@example.com,friend@example.com

# NOTE: the SERVICE-ROLE key is NEVER used by this web app (it would bypass RLS).
# It lives ONLY on the Python "brain" side (publisher/poller) in its own .env — never in Vercel.
